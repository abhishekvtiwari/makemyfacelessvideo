# .env.example — MakeMyFacelessVideo
# All 18 canonical environment variable names with placeholder values only.
# Copy the relevant section to src/.env.local (frontend) and backend/.env (FastAPI).
# NEVER commit files containing real secrets.

# ── Supabase ───────────────────────────────────────────────────────────────────
# Used in browser (Supabase JS client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Used in Next.js API routes (server-only)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Used in browser (OAuth redirect URL builder)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Used in Next.js API routes and NextAuth provider (server-only)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://makemyfacelessvideo.com
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
JWT_SECRET=generate_with_openssl_rand_base64_32

# ── Email — Resend.com (no AWS SES, no SMTP) ───────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
ADMIN_EMAIL=admin@makemyfacelessvideo.com
FROM_EMAIL=noreply@makemyfacelessvideo.com

# ── AI ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# ── Payments — Razorpay ONLY (no Stripe) ──────────────────────────────────────
# RAZORPAY_KEY_ID: safe to pass to frontend via a server-side API route
# RAZORPAY_KEY_SECRET: server-only — never expose to client
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_ENV=development
