# src/.env.local.example
# Copy to src/.env.local and fill in real values. NEVER commit .env.local

# ── Public (safe to expose to browser) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
NEXT_PUBLIC_APP_ENV=development

# ── Server-only (Next.js API routes — never sent to browser) ──────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

JWT_SECRET=generate_with_openssl_rand_base64_32

GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# Same value as NEXT_PUBLIC_SUPABASE_URL — used in server-only route handlers
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

RESEND_API_KEY=re_your_resend_api_key_here
ADMIN_EMAIL=admin@yourdomain.com
FROM_EMAIL=noreply@makemyfacelessvideo.com

ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Razorpay — KEY_ID is passed to frontend via API route only. KEY_SECRET never leaves server.
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
