# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Local Claude config
CLAUDE.local.md

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files — NEVER commit these
.env
.env.local
backend/.env
src/.env.local
*.env

# Keep example files (these are safe to commit)
!.env.example
!backend/.env.example
!src/.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
